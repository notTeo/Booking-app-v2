generator client {
  provider = "prisma-client-js"
  output   = "../dist/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionStatus {
  active
  canceled
  incomplete
  incomplete_expired
  past_due
  paused
  trialing
  unpaid
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique
  stripePriceId        String
  status               SubscriptionStatus
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

enum ShopRole {
  owner
  staff
}

enum InviteStatus {
  pending
  accepted
  expired
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
  NO_SHOW
}

model Shop {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  phone       String?

  // Location
  lat              Float?
  lng              Float?
  formattedAddress String?
  placeId          String?

  timezone    String   @default("Europe/Athens")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members              UserShop[]
  shopWorkingSchedules ShopWorkingSchedule[]
  invites              ShopInvite[]
  services             Service[]
  customers            Customer[]
  bookings             Booking[]
}

model ShopWorkingSchedule {
  id        String    @id @default(cuid())
  shopId    String
  staffId   String?   // null = shop schedule, User.id = staff member schedule
  startDate DateTime
  endDate   DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  days ShopWorkingDay[]

  @@index([shopId])
  @@index([shopId, staffId])
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model ShopWorkingDay {
  id         String    @id @default(cuid())
  scheduleId String
  day        DayOfWeek
  isOpen     Boolean   @default(true)

  schedule ShopWorkingSchedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  hours    ShopWorkingHourRange[]

  @@unique([scheduleId, day])
}

model ShopWorkingHourRange {
  id    String @id @default(cuid())
  dayId String

  startTime String
  endTime   String

  day ShopWorkingDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}

model UserShop {
  id        String   @id @default(cuid())
  userId    String
  shopId    String
  role      ShopRole @default(staff)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  staffServices StaffService[]
  bookings      Booking[]

  @@unique([userId, shopId])
}

model Service {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  description String?
  duration    Int      // minutes
  price       Int      // cents
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staffServices StaffService[]
  bookings      Booking[]
}

model StaffService {
  id          String   @id @default(cuid())
  userShopId  String
  serviceId   String
  userShop    UserShop @relation(fields: [userShopId], references: [id], onDelete: Cascade)
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([userShopId, serviceId])
}

model User {
  id               String        @id @default(cuid())
  name             String
  email            String        @unique
  passwordHash     String?
  isVerified       Boolean       @default(false)
  googleId         String?       @unique
  stripeCustomerId String?       @unique
  subscription     Subscription?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  refreshTokens          RefreshToken[]
  emailVerificationToken EmailVerificationToken?
  passwordResetToken     PasswordResetToken?
  pendingEmailChange     PendingEmailChange?
  userShops              UserShop[]
  sentInvites            ShopInvite[] @relation("InviteCreatedBy")
  acceptedInvites        ShopInvite[] @relation("InviteAcceptedBy")
}

model Customer {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  phone     String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([shopId, phone])
  @@index([shopId])
}

model Booking {
  id         String        @id @default(cuid())
  shopId     String
  customerId String
  serviceId  String
  staffId    String
  date       DateTime
  status     BookingStatus @default(CONFIRMED)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id])
  staff    UserShop @relation(fields: [staffId], references: [id])

  @@index([shopId])
  @@index([shopId, date])
  @@index([staffId, date])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  family    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PendingRegistration {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model PendingEmailChange {
  id        String   @id @default(cuid())
  userId    String   @unique
  newEmail  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShopInvite {
  id           String       @id @default(cuid())
  shopId       String
  email        String
  role         ShopRole     @default(staff)
  status       InviteStatus @default(pending)
  tokenHash    String       @unique
  expiresAt    DateTime
  createdById  String
  acceptedById String?

  shop       Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdBy  User  @relation("InviteCreatedBy",  fields: [createdById],  references: [id])
  acceptedBy User? @relation("InviteAcceptedBy", fields: [acceptedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([email])
}
